# --- СЕКРЕТЫ И НАСТРОЙКИ (Критически важно!) ---
# Никогда не добавляйте файлы конфигурации с паролями и ключами API в Git
.env
.env.local
.env.development.local
config/js/private.json

# --- ЗАВИСИМОСТИ ---
# Папки с библиотеками занимают много места, их всегда можно скачать заново
node_modules/
jspm_packages/
web_modules/

# --- ФАЙЛЫ СБОРКИ И КЭШ ---
# Результаты работы компиляторов и минификаторов (создаются автоматически)
dist/
build/
.next/
.nuxt/
.out/
.cache/

# --- ЛОГИ И ТЕСТЫ ---
# Файлы отчетов об ошибках и результаты тестирования
*.log
npm-debug.log*
yarn-debug.log*
coverage/
.nyc_output/

# --- МУСОР ОПЕРАЦИОННОЙ СИСТЕМЫ И IDE ---
# Служебные файлы Windows, macOS и редакторов кода
.DS_Store
Thumbs.db
.vscode/
.idea/
*.suo
*.ntvs*

.htaccess
.htpasswd

.osp/